# ─── Application ───────────────────────────────────────────────
APP_NAME=Simplify API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# ─── Server ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── MongoDB Atlas ─────────────────────────────────────────────
# Atlas → Database → Connect → Drivers → copy connection string into backend/.env only
# Atlas → Network Access: allow your IP (or 0.0.0.0/0 for local dev)
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=simplify
# If Atlas SSL/IP blocks you temporarily, set true to start the API without DB
MONGODB_OPTIONAL=false

# ─── JWT ───────────────────────────────────────────────────────
JWT_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Gemini ────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_BASE_DELAY_SECONDS=1.0

# ─── RAG / Vector store ────────────────────────────────────────
VECTOR_STORE_PROVIDER=chroma
CHROMA_PERSIST_DIR=./data/chroma
PINECONE_API_KEY=
PINECONE_INDEX_NAME=simplify-documents
# Optional: full host from Pinecone, e.g. my-index-abc123.svc.us-east-1-aws.pinecone.io
# Do not put the index name here.
PINECONE_INDEX_HOST=
PINECONE_NAMESPACE=simplify
PINECONE_DIMENSION=3072
PINECONE_METRIC=cosine
PINECONE_UPSERT_BATCH_SIZE=100
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_TOP_K=6
RAG_MIN_RELEVANCE_SCORE=0.0
RAG_FALLBACK_RELEVANCE_THRESHOLD=0.35
EMBEDDING_BATCH_SIZE=32
CHAT_HISTORY_LIMIT=20
MAX_CHATS_PER_USER=50
MAX_MESSAGES_PER_CHAT=100
MAX_DOCUMENTS_PER_CHAT=8

# ─── File storage ──────────────────────────────────────────────
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=25
ALLOWED_EXTENSIONS=.pdf,.docx,.txt,.md

# Supabase Storage stores original uploaded files. MongoDB still stores metadata.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_BUCKET=documents
SUPABASE_SIGNED_URL_EXPIRY_SECONDS=3600
