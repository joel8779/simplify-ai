# Application
APP_NAME=Simplify API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=simplify
MONGODB_OPTIONAL=false

# JWT auth
JWT_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email OTP verification
OTP_EXPIRE_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_RATE_LIMIT_WINDOW_MINUTES=15
OTP_MAX_REQUESTS_PER_WINDOW=3

# SMTP email
# For Gmail, use an app password, not your normal account password.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@simplify.ai
SMTP_FROM_NAME=Simplify AI
SMTP_USE_TLS=true

# Gemini
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=models/gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_BASE_DELAY_SECONDS=1.0

# RAG / Vector store
# Use pinecone for production. chroma is intended for local development.
VECTOR_STORE_PROVIDER=pinecone
CHROMA_PERSIST_DIR=./data/chroma
PINECONE_API_KEY=
PINECONE_INDEX_NAME=simplify-documents
# Optional: full host from Pinecone. Do not put the index name here.
PINECONE_INDEX_HOST=
PINECONE_NAMESPACE=simplify
PINECONE_DIMENSION=3072
PINECONE_METRIC=cosine
PINECONE_UPSERT_BATCH_SIZE=100
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_TOP_K=6
RAG_MIN_RELEVANCE_SCORE=0.0
RAG_FALLBACK_RELEVANCE_THRESHOLD=0.35
EMBEDDING_BATCH_SIZE=32
CHAT_HISTORY_LIMIT=20
MAX_CHATS_PER_USER=50
MAX_MESSAGES_PER_CHAT=100
MAX_DOCUMENTS_PER_CHAT=8

# Uploads and Supabase Storage
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=25
ALLOWED_EXTENSIONS=.pdf,.docx,.txt,.md
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_BUCKET=documents
SUPABASE_SIGNED_URL_EXPIRY_SECONDS=3600
